# This .gitignore file is specifically for Unity projects using C#
# Recommended for use with IDEs like Visual Studio or JetBrains Rider

/[Aa]ssets/AssetStoreTools*

# Library and Temp folders
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]nityGenerated/

# Memory captures
/[Mm]emoryCaptures/

# Asset compute shader cache
/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Asset log files
/[Aa]ssets/StreamedBytes/

# Never ignore Asset Meta files
!/[Aa]ssets/**/*.meta

# OS generated files
.DS_Store
Thumbs.db

# Visual Studio / JetBrains Rider / VS Code
.vs/
.idea/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.opendb
*.VC.db

# Unity3D Generated File On Crash Reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics
crashlytics-build.properties

# URP/HDRP shader cache
/[Aa]ssets/ShaderCache/

# PlasticSCM
/ignore.conf
.env